-- Funciones
local function updateAll()
    speedLabel.Text = "Speed: " .. speedValue
    inputBox.Text = tostring(speedValue)
end

minimizeButton.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        content.Visible = false
        frame.Size = UDim2.new(0, 220, 0, 34)
        minimizeButton.Text = "+"
    else
        content.Visible = true
        frame.Size = UDim2.new(0, 220, 0, 135)
        minimizeButton.Text = "_"
    end
end)

inputBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local val = tonumber(inputBox.Text)
        if val and val >= 1 and val <= 9999999999999999999999999999999999999999999 then
            speedValue = val
            updateAll()
        else
            inputBox.Text = tostring(speedValue)
        end
    else
        inputBox.Text = tostring(speedValue)
    end
end)

decreaseButton.MouseButton1Click:Connect(function()
    if speedValue > 1 then
        speedValue = speedValue - 1
        updateAll()
    end
end)

increaseButton.MouseButton1Click:Connect(function()
    speedValue = speedValue + 1
    updateAll()
end)

-- Aplicar velocidad por personaje
local function applySpeed(character)
    while true do
        if character and character:FindFirstChild("Humanoid") then
            character.Humanoid.WalkSpeed = speedValue
        end
        wait(0.1)
    end
end

local player = game.Players.LocalPlayer

if player.Character then
    coroutine.wrap(applySpeed)(player.Character)
end

player.CharacterAdded:Connect(function(newCharacter)
    wait(0.5)
    coroutine.wrap(applySpeed)(newCharacter)
end)